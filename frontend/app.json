{
  "expo": {
    "name": "أبو الزهراء",
    "slug": "abu-alzahraa-calling",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "abualzahraa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abualzahra.voip",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "للمكالمات الصوتية",
        "NSContactsUsageDescription": "للوصول إلى جهات الاتصال"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0078D7"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.abualzahra.voip",
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "READ_CONTACTS",
        "WRITE_CONTACTS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0078D7"
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "abu-alzahraa-calling"
      }
    }
  }
}
